# Postgres connection string. On Vercel, add the "Postgres" storage integration
# (or a Neon/Supabase database) to your project and it will inject this for you.
# For local development, point it at any Postgres instance.
DATABASE_URL="postgresql://user:password@localhost:5432/kamrai_lae_view"

# Direct (non-pooled) connection string, used only for running migrations.
# Neon/Vercel Postgres usually expose this as DATABASE_URL_UNPOOLED or
# DIRECT_URL — check your project's Environment Variables list and set
# whichever one it actually uses. Falls back to DATABASE_URL if unset.
DIRECT_URL="postgresql://user:password@localhost:5432/kamrai_lae_view"
