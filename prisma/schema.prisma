// Prisma schema for กำไรและวิว (loan & account management system)

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STAFF
}

enum AccountType {
  BANK
  CASH
}

enum TransactionKind {
  INCOME
  EXPENSE
}

model User {
  id       String @id @default(cuid())
  username String @unique
  password String
  name     String
  role     Role
}

model Account {
  id             String        @id @default(cuid())
  name           String
  type           AccountType
  number         String
  openingBalance Float         @default(0)
  order          Int           @default(0)
  createdAt      DateTime      @default(now())
  transactions   Transaction[]
  wallets        Wallet[]
  loansOut       Loan[]        @relation("LoanOutAccount")
  loansIn        Loan[]        @relation("LoanInAccount")
}

model Wallet {
  id             String        @id @default(cuid())
  name           String
  accountId      String
  account        Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  openingBalance Float         @default(0)
  order          Int           @default(0)
  createdAt      DateTime      @default(now())
  transactions   Transaction[]
  loansOut       Loan[]        @relation("LoanOutWallet")
  loansIn        Loan[]        @relation("LoanInWallet")
}

model Transaction {
  id        String          @id @default(cuid())
  kind      TransactionKind
  date      DateTime
  category  String
  note      String
  amount    Float
  accountId String
  account   Account         @relation(fields: [accountId], references: [id])
  walletId  String?
  wallet    Wallet?         @relation(fields: [walletId], references: [id], onDelete: SetNull)
  createdAt DateTime        @default(now())
}

model Loan {
  id                 String    @id @default(cuid())
  borrower           String
  borrowDate         DateTime
  amount             Float
  interest           Float
  dueDate            DateTime
  penalty            Float
  promisedReturnDate DateTime?
  paid               Boolean   @default(false)
  paidDate           DateTime?
  transferImage      String?
  transferImage2     String?
  repaymentImage     String?
  outAccountId       String?
  outAccount         Account?  @relation("LoanOutAccount", fields: [outAccountId], references: [id], onDelete: SetNull)
  outWalletId        String?
  outWallet          Wallet?   @relation("LoanOutWallet", fields: [outWalletId], references: [id], onDelete: SetNull)
  outTransactionId   String?
  inAccountId        String?
  inAccount          Account?  @relation("LoanInAccount", fields: [inAccountId], references: [id], onDelete: SetNull)
  inWalletId         String?
  inWallet           Wallet?   @relation("LoanInWallet", fields: [inWalletId], references: [id], onDelete: SetNull)
  inTransactionIds   String[]  @default([])
  createdAt          DateTime  @default(now())
}

model Installment {
  id                    String   @id @default(cuid())
  item                  String
  totalAmount           Float
  months                Int
  amounts               Float[]
  startDate             DateTime
  paidMonths            Int      @default(0)
  paymentTransactionIds String[] @default([])
  createdAt             DateTime @default(now())
}
